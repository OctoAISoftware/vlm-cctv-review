# Copy to .env.local for local dev, or pass via PM2 / systemd env block.
# .env.local is in .gitignore so it never gets committed.

# REQUIRED — service-role key for the Supabase instance that hosts the
# qwen35_review_* tables. Without this every annotation write 401s.
SUPABASE_KEY=

# REQUIRED for the "Traduzir com Google" button. Google Cloud Translation
# v2 Basic API key. Without this the /api/translate route returns 503.
GOOGLE_TRANSLATE_KEY=

# Optional — sane defaults for the LocalDC Spark host
# SUPABASE_URL=http://10.5.255.107:54321
# BENCH_RESULTS_DIR=/path/to/vlm-cctv-batch/bench_results
# FRAMES_DIRS=/home/suporte/datasets/cctv-sample-100:/home/suporte/datasets/testaci-frames
